SCENARIO 1: Mobile Product Revenue Report

db.orders.aggregate([
{ $unwind: "$items" },
{
$match: {
"items.product": "Mobile",
"items.price": { $gte: 15000 }
}},
{
$group: {
_id: "$items.product",
total_customers: { $sum: 1 },
total_revenue: { $sum: "$items.price" },
average_price: { $avg: "$items.price" },
minimum_price: { $min: "$items.price" },
maximum_price: { $max: "$items.price" },
customer_names: { $push: "$name" },
first_customer: { $first: "$name" }
}},
{
$out: "mobile_report"
}])

db.mobile_report.find().pretty()
{
  _id: 'Mobile',
  total_customers: 2,
  total_revenue: 30000,
  average_price: 15000,
  minimum_price: 15000,
  maximum_price: 15000,
  customer_names: [
    'Asha',
    'Kiran'
  ],
  first_customer: 'Asha'
}

SCENARIO 2: High Value Products Report

db.orders.aggregate([
{ $unwind: "$items" },
{
$match: {
"items.price": { $gte: 15000 },
"items.product": { $in: ["Mobile", "Laptop"] }
}},
{
$group: {
_id: "$items.product",
number_of_orders: { $sum: 1 },
total_revenue: { $sum: "$items.price" },
average_price: { $avg: "$items.price" },
minimum_price: { $min: "$items.price" },
maximum_price: { $max: "$items.price" },
customer_list: { $push: "$name" }
}},
{
$out: "high_value_products_report"
}])

