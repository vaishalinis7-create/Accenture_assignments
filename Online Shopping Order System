SCENARIO 3: Customer-wise Spending Report

db.orders.aggregate([
{
$project: {
name: 1,
items: 1,
total_products: { $size: "$items" }
}},
{
$match: {
total_products: { $gt: 1 }
}},
{ $unwind: "$items" },
{
$group: {
_id: "$name",
total_amount_spent: { $sum: "$items.price" },
average_price: { $avg: "$items.price" },
minimum_price: { $min: "$items.price" },
maximum_price: { $max: "$items.price" },
products_purchased: { $push: "$items.product" }
}},
{
$match: {
total_amount_spent: { $gte: 30000 }
}},
{
$out: "customer_spending_report"
}])

